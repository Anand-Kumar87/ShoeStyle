// ==========================================
// MongoDB Prisma Schema - ShoeStyle E-commerce
// ==========================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// Authentication Models (NextAuth)
// ==========================================

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("user") // "user" | "admin"
  resetToken     String?
  resetTokenExpiry DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  orders         Order[]
  reviews        Review[]
  wishlist       WishlistItem[]
  cart           CartItem[]
  
  // 🔥 NEW: Address Book Relation
  addresses      UserAddress[]
  
  // 🔥 NEW: Returns Relation
  returns        ReturnRequest[]

  @@map("users")
}

// 🔥 NEW: Address Book Model
model UserAddress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   @default("HOME") // HOME | OFFICE | OTHER
  firstName   String
  lastName    String
  street      String
  apartment   String?
  city        String
  state       String
  zipCode     String
  country     String   @default("IN")
  phone       String
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// Category Model (🔥 NEW: Dynamic Categories)
// ==========================================
model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String     @unique
  description String?
  image       String?
  isActive    Boolean    @default(true)
  
  // For Sub-categories (e.g. Men -> Sneakers)
  parentId    String?    @db.ObjectId
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Category[] @relation("SubCategories")

  products    Product[]  @relation("ProductCategory")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}


// ==========================================
// Product Models
// ==========================================

model Product {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  name           String
  description    String
  price          Float
  compareAtPrice Float?
  image          String
  images         String[]
  
  // Legacy fields (Kept to prevent old code from breaking)
  category       String
  colors         String[]
  sizes          String[]
  stock          Int      @default(0)
  
  // 🔥 NEW: Link to Dynamic Category Model
  categoryId     String?  @db.ObjectId
  categoryRef    Category? @relation("ProductCategory", fields: [categoryId], references: [id])

  isNew          Boolean  @default(false)
  isFeatured     Boolean  @default(false)
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  tags           String[]
  sku            String   @unique
  brand          String?
  weight         Float?
  dimensions     String?
  material       String?
  isActive       Boolean  @default(true)
  isSale         Boolean  @default(false)
  salePrice      Float?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  variants       ProductVariant[] // 🔥 NEW: Product Variants Relation
  orderItems     OrderItem[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  cartItems      CartItem[]
  productViews   ProductView[]

  @@map("products")
}

// 🔥 NEW: Exact Inventory Tracking (Size + Color)
model ProductVariant {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @db.ObjectId
  size          String?
  color         String?
  sku           String   @unique
  stock         Int      @default(0)
  priceOverride Float?   // If a specific size/color costs more
  image         String?  // Specific image for this variant

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Composite unique key for checking duplicates
  @@unique([productId, size, color])
  @@map("product_variants")
}

// ==========================================
// Cart Models
// ==========================================

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  quantity  Int      @default(1)
  size      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, size, color])
  @@map("cart_items")
}

// ==========================================
// Order Models
// ==========================================

model Order {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber String  @unique
  userId      String? @db.ObjectId

  // Customer Information
  firstName   String
  lastName    String
  email       String
  phone       String

  // Shipping Address
  address     String
  apartment   String?
  city        String
  state       String
  zipCode     String
  country     String  @default("IN")

  // Pricing
  subtotal    Float
  shipping    Float   @default(0)
  tax         Float   @default(0)
  discount    Float   @default(0)
  total       Float

  // Status
  status        String @default("PENDING")
  paymentStatus String @default("PENDING")

  paymentMethod   String?
  paymentIntentId String?

  // Coupon
  couponCode     String?
  couponDiscount Float?

  // Tracking
  trackingNumber String?
  carrier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?

  // Notes
  customerNotes  String?
  adminNotes     String?

  ipAddress      String?
  userAgent      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  returns        ReturnRequest[] // 🔥 NEW: Link to Returns

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String  @db.ObjectId
  productId String  @db.ObjectId

  // Product snapshot at time of purchase
  name      String
  slug      String?
  image     String
  price     Float
  quantity  Int
  size      String?
  color     String?
  sku       String?

  createdAt DateTime @default(now())

  // Relations
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  returnItems ReturnItem[] // 🔥 NEW: Link to Returns

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ==========================================
// Return & Exchange Models (🔥 NEW)
// ==========================================

model ReturnRequest {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId      String   @db.ObjectId
  userId       String   @db.ObjectId
  orderNumber  String

  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED | RECEIVED | REFUNDED
  reason       String
  resolution   String   @default("REFUND")  // REFUND | EXCHANGE | STORE_CREDIT
  customerNote String?
  adminNote    String?

  refundAmount Float?
  trackingCode String?
  returnLabel  String?  // URL to the printable label

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  order        Order        @relation(fields: [orderId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  items        ReturnItem[]

  @@map("return_requests")
}

model ReturnItem {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  returnRequestId String   @db.ObjectId
  orderItemId     String   @db.ObjectId
  quantity        Int
  condition       String?  // NEW | WORN | DAMAGED

  // Relations
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])

  @@map("return_items")
}

// ==========================================
// Review Models
// ==========================================

model Review {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  productId          String   @db.ObjectId
  userId             String   @db.ObjectId
  rating             Int      // 1-5
  title              String?
  comment            String
  images             String[] @default([])
  isVerifiedPurchase Boolean  @default(false)
  isApproved         Boolean  @default(false)
  helpfulCount       Int      @default(0)
  reportCount        Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ==========================================
// Wishlist & Coupon & Newsletter (Unchanged)
// ==========================================

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Coupon {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  code               String   @unique
  description        String?
  discountType       String   // PERCENTAGE | FIXED_AMOUNT | FREE_SHIPPING
  discountValue      Float
  minPurchase        Float?
  maxDiscount        Float?
  usageLimit         Int?
  usageCount         Int      @default(0)
  perUserLimit       Int      @default(1)
  isActive           Boolean  @default(true)
  startsAt           DateTime?
  expiresAt          DateTime?
  categories         String[] @default([])
  excludedCategories String[] @default([])
  productIds         String[] @default([])
  excludedProductIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

model Newsletter {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  name           String?
  source         String?   // FOOTER | POPUP | CHECKOUT
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  preferences    Json?

  @@map("newsletter_subscribers")
}

// ==========================================
// Contact, Analytics & Settings (Unchanged)
// ==========================================

model ContactMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     String   @default("NEW") 
  userId     String?  @db.ObjectId
  assignedTo String?
  response   String?
  respondedAt DateTime?
  respondedBy String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contact_messages")
}

model ProductView {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  userId    String?  @db.ObjectId
  sessionId String?
  ipAddress String?
  userAgent String?
  referrer  String?
  viewedAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_views")
}

model SearchQuery {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  query        String
  resultsCount Int      @default(0)
  userId       String?  @db.ObjectId
  sessionId    String?
  filters      Json?
  searchedAt   DateTime @default(now())

  @@map("search_queries")
}

model Setting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  value       String   @db.String
  type        String   @default("string")
  category    String?
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model ShippingZone {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  description           String?
  countries             String[]
  states                String[] @default([])
  zipCodes              String[] @default([])
  baseCost              Float
  perKgCost             Float    @default(0)
  freeShippingThreshold Float?
  minDeliveryDays       Int?
  maxDeliveryDays       Int?
  isActive              Boolean  @default(true)
  priority              Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shipping_zones")
}

model TaxRate {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  country    String
  state      String?
  zipCode    String?
  city       String?
  rate       Float
  isCompound Boolean  @default(false)
  priority   Int      @default(0)
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  type      String
  title     String
  message   String
  link      String?
  icon      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  @@map("notifications")
}

model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  action      String
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

model StoreSettings {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  storeName          String   @default("ShoeStyle")
  contactEmail       String   @default("admin@shoestyle.com")
  defaultCurrency    String   @default("USD")
  taxRate            Float    @default(10.0)
  freeShippingAmount Float    @default(100.0)
  updatedAt          DateTime @updatedAt

  @@map("store_settings")
}

model BankDetail {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  bankName      String
  accountName   String
  accountNumber String
  ifscCode      String
  createdAt     DateTime @default(now())

  @@map("bank_details")
}